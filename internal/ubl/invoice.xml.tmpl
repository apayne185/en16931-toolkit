<?xml version="1.0" encoding="UTF-8"?>
<!--
  UBL 2.1 Invoice — EN 16931:2017 conformant
  Generated by en16931-toolkit (github.com/apayne185/en16931-toolkit)
-->
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

  <!-- BT-24: Specification identifier (conformance profile) -->
  <cbc:CustomizationID>{{ specID .SpecificationID }}</cbc:CustomizationID>
  <cbc:ProfileID>urn:fdc:peppol.eu:2017:poacc:billing:01:1.0</cbc:ProfileID>

  <!-- BT-1..5: Invoice header -->
  <cbc:ID>{{ x .Number }}</cbc:ID>
  <cbc:IssueDate>{{ .IssueDate }}</cbc:IssueDate>
  {{- if .DueDate }}
  <cbc:DueDate>{{ .DueDate }}</cbc:DueDate>
  {{- end }}
  <cbc:InvoiceTypeCode>{{ .TypeCode }}</cbc:InvoiceTypeCode>
  {{- range .Notes }}
  <cbc:Note>{{ x . }}</cbc:Note>
  {{- end }}
  <cbc:DocumentCurrencyCode>{{ .Currency }}</cbc:DocumentCurrencyCode>
  {{- if .BuyerReference }}
  <cbc:BuyerReference>{{ x .BuyerReference }}</cbc:BuyerReference>
  {{- end }}

  {{- if .OrderReference }}
  <cac:OrderReference>
    <cbc:ID>{{ x .OrderReference }}</cbc:ID>
  </cac:OrderReference>
  {{- end }}

  <!-- BT-25: Preceding invoice reference (mandatory on credit notes) -->
  {{- if .PrecedingInvoiceRef }}
  <cac:BillingReference>
    <cac:InvoiceDocumentReference>
      <cbc:ID>{{ x .PrecedingInvoiceRef }}</cbc:ID>
    </cac:InvoiceDocumentReference>
  </cac:BillingReference>
  {{- end }}

  <!-- BG-4: Seller -->
  <cac:AccountingSupplierParty>
    {{- template "party" .Seller }}
  </cac:AccountingSupplierParty>

  <!-- BG-7: Buyer -->
  <cac:AccountingCustomerParty>
    {{- template "party" .Buyer }}
  </cac:AccountingCustomerParty>

  <!-- BG-16: Payment instructions -->
  {{- range .PaymentMeans }}
  <cac:PaymentMeans>
    <cbc:PaymentMeansCode>{{ .TypeCode }}</cbc:PaymentMeansCode>
    {{- if .RemittanceInfo }}
    <cbc:PaymentID>{{ x .RemittanceInfo }}</cbc:PaymentID>
    {{- end }}
    {{- if .AccountID }}
    <cac:PayeeFinancialAccount>
      <cbc:ID>{{ x .AccountID }}</cbc:ID>
      {{- if .AccountName }}
      <cbc:Name>{{ x .AccountName }}</cbc:Name>
      {{- end }}
      {{- if .ServiceProviderID }}
      <cac:FinancialInstitutionBranch>
        <cbc:ID>{{ x .ServiceProviderID }}</cbc:ID>
      </cac:FinancialInstitutionBranch>
      {{- end }}
    </cac:PayeeFinancialAccount>
    {{- end }}
  </cac:PaymentMeans>
  {{- end }}

  <!-- BG-20: Document-level allowances -->
  {{- range .Allowances }}
  <cac:AllowanceCharge>
    <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
    {{- if .ReasonCode }}
    <cbc:AllowanceChargeReasonCode>{{ x .ReasonCode }}</cbc:AllowanceChargeReasonCode>
    {{- end }}
    <cbc:AllowanceChargeReason>{{ x .Reason }}</cbc:AllowanceChargeReason>
    <cbc:Amount currencyID="{{ $.Currency }}">{{ amt .Amount }}</cbc:Amount>
    <cac:TaxCategory>
      <cbc:ID>{{ .VATCategory }}</cbc:ID>
      <cbc:Percent>{{ .VATRate }}</cbc:Percent>
      <cac:TaxScheme><cbc:ID>VAT</cbc:ID></cac:TaxScheme>
    </cac:TaxCategory>
  </cac:AllowanceCharge>
  {{- end }}

  <!-- BG-21: Document-level charges -->
  {{- range .Charges }}
  <cac:AllowanceCharge>
    <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
    {{- if .ReasonCode }}
    <cbc:AllowanceChargeReasonCode>{{ x .ReasonCode }}</cbc:AllowanceChargeReasonCode>
    {{- end }}
    <cbc:AllowanceChargeReason>{{ x .Reason }}</cbc:AllowanceChargeReason>
    <cbc:Amount currencyID="{{ $.Currency }}">{{ amt .Amount }}</cbc:Amount>
    <cac:TaxCategory>
      <cbc:ID>{{ .VATCategory }}</cbc:ID>
      <cbc:Percent>{{ .VATRate }}</cbc:Percent>
      <cac:TaxScheme><cbc:ID>VAT</cbc:ID></cac:TaxScheme>
    </cac:TaxCategory>
  </cac:AllowanceCharge>
  {{- end }}

  <!-- BG-23: VAT breakdown -->
  <cac:TaxTotal>
    <cbc:TaxAmount currencyID="{{ .Currency }}">{{ amt .Totals.TaxAmount }}</cbc:TaxAmount>
    {{- range .VATBreakdown }}
    <cac:TaxSubtotal>
      <cbc:TaxableAmount currencyID="{{ $.Currency }}">{{ amt .TaxableAmount }}</cbc:TaxableAmount>
      <cbc:TaxAmount currencyID="{{ $.Currency }}">{{ amt .TaxAmount }}</cbc:TaxAmount>
      <cac:TaxCategory>
        <cbc:ID>{{ .Category }}</cbc:ID>
        <cbc:Percent>{{ .Rate }}</cbc:Percent>
        {{- if .ExemptionReasonCode }}
        <cbc:TaxExemptionReasonCode>{{ x .ExemptionReasonCode }}</cbc:TaxExemptionReasonCode>
        {{- end }}
        {{- if .ExemptionReason }}
        <cbc:TaxExemptionReason>{{ x .ExemptionReason }}</cbc:TaxExemptionReason>
        {{- end }}
        <cac:TaxScheme><cbc:ID>VAT</cbc:ID></cac:TaxScheme>
      </cac:TaxCategory>
    </cac:TaxSubtotal>
    {{- end }}
  </cac:TaxTotal>

  <!-- BG-22: Document monetary totals -->
  <cac:LegalMonetaryTotal>
    <cbc:LineExtensionAmount currencyID="{{ .Currency }}">{{ amt .Totals.LineNetTotal }}</cbc:LineExtensionAmount>
    <cbc:TaxExclusiveAmount currencyID="{{ .Currency }}">{{ amt .Totals.TaxExclusiveAmount }}</cbc:TaxExclusiveAmount>
    <cbc:TaxInclusiveAmount currencyID="{{ .Currency }}">{{ amt .Totals.TaxInclusiveAmount }}</cbc:TaxInclusiveAmount>
    {{- if .Totals.AllowanceTotal }}
    <cbc:AllowanceTotalAmount currencyID="{{ .Currency }}">{{ amt .Totals.AllowanceTotal }}</cbc:AllowanceTotalAmount>
    {{- end }}
    {{- if .Totals.ChargeTotal }}
    <cbc:ChargeTotalAmount currencyID="{{ .Currency }}">{{ amt .Totals.ChargeTotal }}</cbc:ChargeTotalAmount>
    {{- end }}
    {{- if .Totals.PrepaidAmount }}
    <cbc:PrepaidAmount currencyID="{{ .Currency }}">{{ amt .Totals.PrepaidAmount }}</cbc:PrepaidAmount>
    {{- end }}
    {{- if .Totals.RoundingAmount }}
    <cbc:PayableRoundingAmount currencyID="{{ .Currency }}">{{ amt .Totals.RoundingAmount }}</cbc:PayableRoundingAmount>
    {{- end }}
    <cbc:PayableAmount currencyID="{{ .Currency }}">{{ amt .Totals.PayableAmount }}</cbc:PayableAmount>
  </cac:LegalMonetaryTotal>

  <!-- BG-25: Invoice lines -->
  {{- range .Lines }}
  <cac:InvoiceLine>
    <cbc:ID>{{ x .ID }}</cbc:ID>
    {{- if .Note }}
    <cbc:Note>{{ x .Note }}</cbc:Note>
    {{- end }}
    <cbc:InvoicedQuantity unitCode="{{ .QuantityUnit }}">{{ qty .Quantity }}</cbc:InvoicedQuantity>
    <cbc:LineExtensionAmount currencyID="{{ $.Currency }}">{{ amt .NetAmount }}</cbc:LineExtensionAmount>
    {{- if .OrderLineRef }}
    <cac:OrderLineReference><cbc:LineID>{{ x .OrderLineRef }}</cbc:LineID></cac:OrderLineReference>
    {{- end }}

    {{- range .Allowances }}
    <cac:AllowanceCharge>
      <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
      {{- if .ReasonCode }}<cbc:AllowanceChargeReasonCode>{{ x .ReasonCode }}</cbc:AllowanceChargeReasonCode>{{- end }}
      {{- if .Reason }}<cbc:AllowanceChargeReason>{{ x .Reason }}</cbc:AllowanceChargeReason>{{- end }}
      <cbc:Amount currencyID="{{ $.Currency }}">{{ amt .Amount }}</cbc:Amount>
    </cac:AllowanceCharge>
    {{- end }}
    {{- range .Charges }}
    <cac:AllowanceCharge>
      <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
      {{- if .ReasonCode }}<cbc:AllowanceChargeReasonCode>{{ x .ReasonCode }}</cbc:AllowanceChargeReasonCode>{{- end }}
      {{- if .Reason }}<cbc:AllowanceChargeReason>{{ x .Reason }}</cbc:AllowanceChargeReason>{{- end }}
      <cbc:Amount currencyID="{{ $.Currency }}">{{ amt .Amount }}</cbc:Amount>
    </cac:AllowanceCharge>
    {{- end }}

    <cac:Item>
      {{- if .Item.Description }}
      <cbc:Description>{{ x .Item.Description }}</cbc:Description>
      {{- end }}
      <cbc:Name>{{ x .Item.Name }}</cbc:Name>
      {{- if .Item.SellerID }}
      <cac:SellersItemIdentification><cbc:ID>{{ x .Item.SellerID }}</cbc:ID></cac:SellersItemIdentification>
      {{- end }}
      {{- if .Item.StandardID }}
      <cac:StandardItemIdentification>
        <cbc:ID schemeID="0160">{{ x .Item.StandardID }}</cbc:ID>
      </cac:StandardItemIdentification>
      {{- end }}
      <cac:ClassifiedTaxCategory>
        <cbc:ID>{{ .VAT.Category }}</cbc:ID>
        <cbc:Percent>{{ .VAT.Rate }}</cbc:Percent>
        <cac:TaxScheme><cbc:ID>VAT</cbc:ID></cac:TaxScheme>
      </cac:ClassifiedTaxCategory>
    </cac:Item>
    <cac:Price>
      <cbc:PriceAmount currencyID="{{ $.Currency }}">{{ amt .Price.Amount }}</cbc:PriceAmount>
      {{- if .Price.BaseQuantity }}
      <cbc:BaseQuantity unitCode="{{ .Price.BaseQuantityUnit }}">{{ qty .Price.BaseQuantity }}</cbc:BaseQuantity>
      {{- end }}
    </cac:Price>
  </cac:InvoiceLine>
  {{- end }}

</Invoice>

{{- define "party" }}
    <cac:Party>
      {{- if .VATID }}
      <cac:PartyIdentification>
        <cbc:ID schemeID="0088">{{ x .VATID }}</cbc:ID>
      </cac:PartyIdentification>
      {{- end }}
      <cac:PartyName>
        <cbc:Name>{{ x .Name }}</cbc:Name>
      </cac:PartyName>
      <cac:PostalAddress>
        {{- if .Address.Street }}
        <cbc:StreetName>{{ x .Address.Street }}</cbc:StreetName>
        {{- end }}
        {{- if .Address.Street2 }}
        <cbc:AdditionalStreetName>{{ x .Address.Street2 }}</cbc:AdditionalStreetName>
        {{- end }}
        {{- if .Address.City }}
        <cbc:CityName>{{ x .Address.City }}</cbc:CityName>
        {{- end }}
        {{- if .Address.PostCode }}
        <cbc:PostalZone>{{ x .Address.PostCode }}</cbc:PostalZone>
        {{- end }}
        {{- if .Address.Subdivision }}
        <cbc:CountrySubentity>{{ x .Address.Subdivision }}</cbc:CountrySubentity>
        {{- end }}
        <cac:Country>
          <cbc:IdentificationCode>{{ .Address.Country }}</cbc:IdentificationCode>
        </cac:Country>
      </cac:PostalAddress>
      {{- if .VATID }}
      <cac:PartyTaxScheme>
        <cbc:CompanyID>{{ x .VATID }}</cbc:CompanyID>
        <cac:TaxScheme><cbc:ID>VAT</cbc:ID></cac:TaxScheme>
      </cac:PartyTaxScheme>
      {{- end }}
      <cac:PartyLegalEntity>
        <cbc:RegistrationName>{{ x .Name }}</cbc:RegistrationName>
        {{- if .LegalID }}
        <cbc:CompanyID>{{ x .LegalID }}</cbc:CompanyID>
        {{- end }}
      </cac:PartyLegalEntity>
      {{- if .ContactName }}
      <cac:Contact>
        <cbc:Name>{{ x .ContactName }}</cbc:Name>
        {{- if .ContactEmail }}
        <cbc:ElectronicMail>{{ x .ContactEmail }}</cbc:ElectronicMail>
        {{- end }}
      </cac:Contact>
      {{- end }}
    </cac:Party>
{{- end }}
